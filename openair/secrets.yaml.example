# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit real credentials.
# ESPHome searches for secrets.yaml starting from the config directory and
# going up, so one file at the openair/ root covers all installations.

wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# Shown on fallback AP when device cannot connect to WiFi
wifi_ap_password: "ChangeMe@123!"

# OTA update password — use a long random string
ota_password: "set_a_long_random_password_here"

# ESPHome API encryption key — generate with: esphome keygen
api_encryption_key: "paste-your-generated-key-here"
